OIDC_ISSUER=http://keycloak:8080/realms/graph-mcp-vault
OIDC_AUDIENCE=graph-mcp-vault
# Optional: override the OIDC discovery URL (defaults to ${OIDC_ISSUER}/.well-known/openid-configuration)
# OIDC_DISCOVERY_URL=
JWKS_CACHE_TTL=3600
METADATA_CACHE_TTL=3600
# Optional: comma-separated list of scopes to expose in OAuth metadata (defaults to all upstream scopes)
# SCOPES_ALLOWLIST=openid,profile,email,offline_access
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
# Optional overrides for the bundled Keycloak dev container.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
HOST=0.0.0.0
PORT=8000
DEFAULT_NAMESPACE=default
LOG_LEVEL=info
# Empty = no CORS enforcement (no Access-Control-Allow-Origin header sent; browser clients blocked by same-origin policy).
# Set to a comma-separated list of allowed origins, or * to allow all origins (local dev only).
ALLOWED_ORIGINS=
