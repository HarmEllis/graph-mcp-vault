OIDC_ISSUER=http://keycloak:8080/realms/graph-mcp-vault
OIDC_AUDIENCE=graph-mcp-vault
# Optional: override the OIDC discovery URL (defaults to ${OIDC_ISSUER}/.well-known/openid-configuration)
# OIDC_DISCOVERY_URL=
# Public URL of this server, used in OAuth metadata and WWW-Authenticate headers.
# Must be reachable by MCP clients. Defaults to http://localhost:${PORT}.
# PUBLIC_URL=https://graph-mcp-vault.example.com
JWKS_CACHE_TTL=3600
METADATA_CACHE_TTL=3600
# Optional: comma-separated list of scopes to expose in OAuth metadata and include
# in the scope injection proxy. Defaults to all upstream scopes (or "openid" as fallback).
# SCOPES_ALLOWLIST=openid,profile,email,offline_access
# Optional: proxy the upstream authorization endpoint through /authorize to inject
# a scope parameter when the MCP client omits it. Enable this if your OIDC provider
# rejects authorization requests with "scope is required" (e.g. Pocket ID).
# Requires SCOPES_ALLOWLIST to be set for meaningful scope values; falls back to "openid".
# INJECT_MISSING_SCOPE=false
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
# Optional overrides for the bundled Keycloak dev container.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
HOST=0.0.0.0
PORT=8000
DEFAULT_NAMESPACE=default
LOG_LEVEL=info
# Empty = no CORS enforcement (no Access-Control-Allow-Origin header sent; browser clients blocked by same-origin policy).
# Set to a comma-separated list of allowed origins, or * to allow all origins (local dev only).
ALLOWED_ORIGINS=
