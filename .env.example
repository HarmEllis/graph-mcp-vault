# ── OIDC / Authentication ──────────────────────────────────────────────────────
# Base URL of your OIDC provider (must match the `iss` claim in access tokens).
OIDC_ISSUER=https://id.example.com

# Expected `aud` claim in incoming JWTs.
OIDC_AUDIENCE=graph-mcp-vault

# Optional: override the OIDC discovery URL (defaults to ${OIDC_ISSUER}/.well-known/openid-configuration)
# OIDC_DISCOVERY_URL=

# Seconds to cache the provider's JWKS response (default: 3600)
JWKS_CACHE_TTL=3600

# Minimum seconds between forced JWKS refreshes — flood protection (default: 30)
JWKS_FORCE_REFRESH_MIN_INTERVAL_SECONDS=30

# Timeout in milliseconds for JWKS fetch requests (default: 5000)
JWKS_FETCH_TIMEOUT_MS=5000

# When true, serve stale JWKS on fetch error instead of failing (default: false)
# JWKS_ALLOW_STALE_ON_ERROR=false

# Maximum allowed token lifetime in seconds (exp - iat); tokens exceeding this are rejected (default: 3600)
MAX_TOKEN_LIFETIME_SECONDS=3600

# ── Request limits ─────────────────────────────────────────────────────────────
# Maximum request body size in bytes before returning 413 (default: 262144 = 256 KiB)
MAX_REQUEST_BODY_BYTES=262144

# ── Server ────────────────────────────────────────────────────────────────────
# Public URL of this server, used in OAuth metadata and WWW-Authenticate headers.
# Must be reachable by MCP clients.
PUBLIC_URL=https://graph-mcp-vault.example.com

HOST=0.0.0.0
PORT=8000

# Comma-separated CORS origins; * for any (local dev only); empty = no cross-origin requests
ALLOWED_ORIGINS=

# ── Namespaces ────────────────────────────────────────────────────────────────
DEFAULT_NAMESPACE=default

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── OIDC scopes ───────────────────────────────────────────────────────────────
# Comma-separated scopes exposed in OAuth metadata (recommended: openid,profile,email)
SCOPES_ALLOWLIST=openid,profile,email

# ── Metadata cache ────────────────────────────────────────────────────────────
METADATA_CACHE_TTL=3600

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── Versioning ────────────────────────────────────────────────────────────────
# Hard ceiling on stored versions per entry. 0 = versioning disabled globally.
# Users cannot exceed this value via namespace or entry settings (default: 10).
# MAX_VERSIONS_LIMIT=10
